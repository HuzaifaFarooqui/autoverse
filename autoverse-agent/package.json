{
    "name": "autoverse-agent",
    "version": "2.5.2",
    "description": "Zero-Config AI customer service chatbot for any website. Auto-scrapes, learns products, handles orders. Powered by Groq LLMs.",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "browser": "dist/browser.mjs",
    "exports": {
        ".": {
            "browser": {
                "types": "./dist/browser.d.mts",
                "import": "./dist/browser.mjs"
            },
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        },
        "./widget": {
            "types": "./dist/browser.d.mts",
            "import": "./dist/browser.mjs"
        }
    },
    "sideEffects": [
        "./dist/browser.mjs"
    ],
    "files": [
        "dist/",
        "README.md"
    ],
    "scripts": {
        "build": "tsup",
        "build:types-only": "tsc --emitDeclarationOnly --outDir dist",
        "start": "node dist/index.js",
        "dev": "ts-node --project tsconfig.dev.json src/index.ts",
        "serve": "ts-node --project tsconfig.dev.json examples/serve.ts",
        "test": "vitest run",
        "prepublishOnly": "npm run build"
    },
    "keywords": [
        "groq",
        "rag",
        "agent",
        "customer-service",
        "chatbot",
        "widget",
        "ai",
        "npm-package"
    ],
    "author": "Antigravity",
    "license": "MIT",
    "dependencies": {
        "axios": "^1.6.2",
        "cheerio": "^1.0.0-rc.12",
        "cors": "^2.8.6",
        "express": "^5.2.1",
        "uuid": "^9.0.1"
    },
    "devDependencies": {
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/node": "^20.10.0",
        "@types/uuid": "^9.0.7",
        "@vitest/ui": "^4.0.18",
        "dotenv": "^16.3.1",
        "ts-node": "^10.9.1",
        "tsup": "^8.5.0",
        "typescript": "^5.3.2",
        "vitest": "^4.0.18"
    }
}