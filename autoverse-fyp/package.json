{
    "name": "autoverse-fyp",
    "version": "1.0.1",
    "description": "Zero-Config AI customer service chatbot for any website. Auto-scrapes, learns products, handles orders. Powered by Groq LLMs.",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "browser": "dist/browser.mjs",
    "exports": {
        ".": {
            "browser": {
                "types": "./dist/browser.d.mts",
                "import": "./dist/browser.mjs"
            },
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        },
        "./widget": {
            "types": "./dist/browser.d.mts",
            "import": "./dist/browser.mjs"
        }
    },
    "sideEffects": [
        "./dist/browser.mjs"
    ],
    "files": [
        "dist/",
        "README.md"
    ],
    "scripts": {
        "build": "tsup",
        "prepublishOnly": "npm run build"
    },
    "keywords": [
        "groq",
        "rag",
        "agent",
        "customer-service",
        "chatbot",
        "widget",
        "ai",
        "npm-package"
    ],
    "author": "Antigravity",
    "license": "MIT",
    "dependencies": {},
    "devDependencies": {
        "tsup": "^8.5.0",
        "typescript": "^5.3.2"
    }
}